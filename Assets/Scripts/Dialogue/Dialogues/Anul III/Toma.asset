  m_Script: {fileID: 11500000, guid: 34f0474bfe694724a8b8b18a68526953, type: 3}
  m_Name: Toma
  m_EditorClassIdentifier: Assembly-CSharp::DialogueDataSO
  lines:
  - text: "Modul cum spa\u021Biul poate lua form\u0103 ne influen\u021Beaz\u0103
      mai mult dec\xE2t putem observa."
  - text: "Este important s\u0103 avem \xEEn vedere imaginea de asamblu."
  - text: "\xCEn acest an apar noi tipuri de oportunit\u0103\u021Bi, dar \u0219i
      de provoc\u0103ri."
